<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- AppBar/Header -->
    <RelativeLayout
        android:id="@+id/rlHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back Button"
            android:padding="2dp"
            android:src="@drawable/backbtn" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:layout_toEndOf="@id/btnBack"
            android:fontFamily="@font/bevietnamprosemibold"
            android:text="Attendance Tracker"
            android:textColor="@color/white"
            android:textSize="20sp" />

        <ImageView
            android:id="@+id/btnTimetable"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_toStartOf="@id/btnResetAll"
            android:layout_centerVertical="true"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Timetable"
            android:padding="4dp"
            android:src="@drawable/baseline_calendar_today_24"
            app:tint="@color/white" />

        <ImageView
            android:id="@+id/btnResetAll"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Reset All"
            android:padding="6dp"
            android:src="@drawable/baseline_delete_24"
            app:tint="@color/lightRed" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/rlHeader">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Today's Schedule Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvTodaySchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/darkGrey2"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bevietnamprosemibold"
                        android:text="Today's Classes Schedule"
                        android:textColor="@color/mediumGreen"
                        android:textSize="14sp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:background="#22FFFFFF" />

                    <LinearLayout
                        android:id="@+id/llTodayClasses"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Summary Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/darkGrey2"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:layout_constraintTop_toBottomOf="@id/cvTodaySchedule">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- Spinner for Active Semester -->
                    <TextView
                        android:id="@+id/tvSemesterLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/bevietnamprolight"
                        android:text="Active Semester:"
                        android:textColor="#AAAAAA"
                        android:textSize="12sp"
                        app:layout_constraintBottom_toTopOf="@id/spSemester"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <Spinner
                        android:id="@+id/spSemester"
                        android:layout_width="160dp"
                        android:layout_height="40dp"
                        android:layout_marginTop="4dp"
                        android:backgroundTint="@color/white"
                        android:spinnerMode="dropdown"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvSemesterLabel" />

                    <!-- Reset Button for Selected Semester -->
                    <Button
                        android:id="@+id/btnResetSem"
                        style="?android:attr/borderlessButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:fontFamily="@font/bevietnamprolight"
                        android:text="Reset Sem"
                        android:textColor="@color/lightRed"
                        android:textSize="11sp"
                        app:layout_constraintBottom_toBottomOf="@id/spSemester"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/spSemester" />

                    <View
                        android:id="@+id/divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="#33FFFFFF"
                        app:layout_constraintTop_toBottomOf="@id/spSemester" />

                    <!-- Overall Attendance Circle / Percent -->
                    <TextView
                        android:id="@+id/tvOverallPercent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="@font/bevietnamprosemibold"
                        android:text="100%"
                        android:textColor="@color/white"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/divider" />

                    <TextView
                        android:id="@+id/tvOverallTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/bevietnamprosemibold"
                        android:text="Overall Attendance"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        app:layout_constraintStart_toEndOf="@id/tvOverallPercent"
                        app:layout_constraintTop_toBottomOf="@id/divider" />

                    <TextView
                        android:id="@+id/tvOverallCounts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:fontFamily="@font/bevietnamprolight"
                        android:text="0 / 0 classes attended"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        app:layout_constraintStart_toEndOf="@id/tvOverallPercent"
                        app:layout_constraintTop_toBottomOf="@id/tvOverallTitle" />

                    <ProgressBar
                        android:id="@+id/pbOverallAttendance"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="8dp"
                        android:layout_marginTop="16dp"
                        android:max="100"
                        android:progress="100"
                        android:progressTint="@color/mediumGreen"
                        app:layout_constraintTop_toBottomOf="@id/tvOverallPercent" />

                    <!-- Smart Status Message -->
                    <TextView
                        android:id="@+id/tvOverallStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/bevietnamprolight"
                        android:text="No classes registered yet. Maintain 100%!"
                        android:textColor="#AAAAAA"
                        android:textSize="13sp"
                        app:layout_constraintTop_toBottomOf="@id/pbOverallAttendance" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick Preseed Layout when list is empty -->
            <LinearLayout
                android:id="@+id/llEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/cvSummary">

                <ImageView
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/baseline_add_box_24"
                    app:tint="#44FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/bevietnamprosemibold"
                    android:text="No Subjects Found"
                    android:textColor="@color/white"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="Pre-populate with standard subjects or add your own custom subjects manually."
                    android:textColor="#888888"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnPreseed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/purpleblue"
                    android:fontFamily="@font/bevietnamprosemibold"
                    android:text="Pre-seed Curriculum"
                    android:textColor="@color/white" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAttendanceSubjects"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clipToPadding="false"
                android:paddingBottom="80dp"
                app:layout_constraintTop_toBottomOf="@id/cvSummary"
                tools:listitem="@layout/item_attendance_subject" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- FAB to Add Subject -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddSubject"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Add Custom Subject"
        android:src="@drawable/baseline_add_box_24"
        app:backgroundTint="@color/purpleblue"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:tint="@color/white" />

    <!-- Progress Overlay -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>