<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/darkGrey2"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Subject Name -->
        <TextView
            android:id="@+id/tvSubjectName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bevietnamprosemibold"
            android:text="Microprocessors"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnEdit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Badge (Subject/Lab) -->
        <TextView
            android:id="@+id/tvTypeBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/bevietnamprolight"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="SUBJECT"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubjectName" />

        <!-- Edit Button -->
        <ImageView
            android:id="@+id/btnEdit"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Edit Subject"
            android:padding="6dp"
            android:src="@drawable/baseline_edit_24"
            app:layout_constraintEnd_toStartOf="@id/btnDelete"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/lightGrey" />

        <!-- Delete Button -->
        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete Subject"
            android:padding="6dp"
            android:src="@drawable/baseline_delete_24"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/lightRed" />

        <!-- Percentage text -->
        <TextView
            android:id="@+id/tvPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="@font/bevietnamprosemibold"
            android:text="80%"
            android:textColor="@color/mediumGreen"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTypeBadge" />

        <!-- Ratio Text (Attended / Scheduled) -->
        <TextView
            android:id="@+id/tvAttendanceCounts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/bevietnamprolight"
            android:text="12 / 15 classes"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvPercentage"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/pbAttendance"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="80"
            android:progressTint="@color/mediumGreen"
            app:layout_constraintTop_toBottomOf="@id/tvPercentage" />

        <!-- Smart warning / status message -->
        <TextView
            android:id="@+id/tvStatusMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/bevietnamprolight"
            android:text="Safe! You can miss next 2 classes."
            android:textColor="@color/mediumGreen"
            android:textSize="12sp"
            app:layout_constraintTop_toBottomOf="@id/pbAttendance" />

        <!-- Quick Incrementor Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tvStatusMessage">

            <!-- Present Button -->
            <Button
                android:id="@+id/btnPresent"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/mediumGreen"
                android:fontFamily="@font/bevietnamprosemibold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Present (+1)"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="8dp" />

            <!-- Absent Button -->
            <Button
                android:id="@+id/btnAbsent"
                android:layout_width="0dp"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:backgroundTint="@color/lightRed"
                android:fontFamily="@font/bevietnamprosemibold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Absent (+1)"
                android:textColor="@color/white"
                android:textSize="12sp"
                app:cornerRadius="8dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>