<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/darkGrey2"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/btnDeleteSlot"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSlotSubjectName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/bevietnamprosemibold"
                android:text="Operating Systems"
                android:textColor="@color/white"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvSlotTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/bevietnamprolight"
                android:text="09:00 AM - 10:00 AM"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnDeleteSlot"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete Slot"
            android:padding="4dp"
            android:src="@drawable/baseline_delete_24"
            app:tint="@color/lightRed" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>