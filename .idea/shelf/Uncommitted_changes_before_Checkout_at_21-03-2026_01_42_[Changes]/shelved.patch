+            galleryLauncher.launch("image/*")
 
         }
 
         binding.btnNextCompleteProfile.setOnClickListener {
+            if (validateField()) {
+                val name = binding.etNameCompleteProfile.toString()
+                val profilePhoto = binding.profilePhoto.toString()
+                val user = hashMapOf(
+                    "name" to name,
+                    "profile_photo" to profilePhoto
+                )
 
+                db.collection("users")
